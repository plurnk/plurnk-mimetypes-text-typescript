# antlr-ng generated parser/lexer/visitor — built by `npm run build:grammar`.
# Vendored base classes (LexerBase, ParserBase) coexist in src/generated/ and
# stay tracked; everything else there is build output.
src/generated/*
!src/generated/TypeScriptLexerBase.ts
!src/generated/TypeScriptParserBase.ts
