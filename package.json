{
    "name": "@plurnk/plurnk-mimetypes-text-typescript",
    "version": "0.3.0",
    "description": "text/typescript and text/javascript mimetype handler for plurnk-service. ANTLR-backed extraction; the TS grammar handles plain JS as a subset.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=25"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/typescript",
                "glyph": "🔷",
                "extensions": [
                    ".ts",
                    ".tsx",
                    ".mts",
                    ".cts"
                ]
            },
            {
                "name": "text/javascript",
                "glyph": "🟨",
                "extensions": [
                    ".js",
                    ".mjs",
                    ".cjs",
                    ".jsx"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "grammar/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:grammar": "plurnk-mimetypes-compile",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:grammar && npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "@plurnk/plurnk-mimetypes": "^0.6.0",
        "antlr4ng": "^3.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "antlr-ng": "^1.0.10",
        "typescript": "^6.0.3"
    }
}
